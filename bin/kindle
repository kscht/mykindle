#!/usr/bin/env python3
"""kindle — подготовка книг/документов и заливка на Kindle (локально, по USB).

  kindle convert [подстрока]   inbox -> staging (конвертация + впекание тегов)
  kindle push                  staging -> Kindle /documents (нужен воткнутый Kindle)
  kindle status                что в inbox / staging / на устройстве
  kindle sync                  convert + push

Теги задаются файлами _kindle.md в папках inbox (см. README), каскадом по
вложенности. Формат вывода: KFX (богатое форматирование) с фолбэком на MOBI6;
PDF заливается как есть. Зависимостей вне stdlib нет.
"""
import os
import re
import shutil
import subprocess
import sys
from concurrent.futures import ThreadPoolExecutor, as_completed
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
INBOX = ROOT / "inbox"
STAGING = ROOT / "staging"
STATE = ROOT / ".state"

# --- OS-специфика (macOS по умолчанию; переопределяется через env) ---
CAL = Path(os.environ.get("CALIBRE_BIN", "/Applications/calibre.app/Contents/MacOS"))
EBOOK_CONVERT = str(CAL / "ebook-convert")
EBOOK_META = str(CAL / "ebook-meta")
MTP_CLI = os.environ.get("MTP_CLI", "/Applications/OpenMTP.app/Contents/Resources/bin/mtp-cli")
PROFILE = os.environ.get("KINDLE_PROFILE", "kindle_pw")
RICH = os.environ.get("KINDLE_RICH_FORMAT", "kfx")  # формат богатого вывода: kfx | mobi
KINDLE_DOCS = "/documents"

SKIP_NAMES = {"_kindle.md", ".DS_Store", ".gitkeep"}
EBOOK_EXTS = {".epub", ".fb2", ".mobi", ".azw3", ".azw", ".docx", ".doc",
              ".txt", ".md", ".rtf", ".htmlz", ".html", ".lit", ".pdb"}


def run(cmd, **kw):
    return subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE,
                          text=True, encoding="utf-8", errors="replace", **kw)


def strip_quotes(s):
    s = s.strip()
    if len(s) >= 2 and s[0] == s[-1] and s[0] in "\"'":
        return s[1:-1]
    return s


def parse_kindle_md(path):
    """Разобрать frontmatter _kindle.md в dict. Поддержка key: value,
    key: [a, b, c] и блочных списков (- item). Без внешних зависимостей."""
    text = path.read_text(encoding="utf-8", errors="replace")
    m = re.match(r"^---\s*\n(.*?)\n---\s*\n?", text, re.S)
    block = m.group(1) if m else text
    data = {}
    cur_key = None
    for line in block.splitlines():
        if not line.strip() or line.lstrip().startswith("#"):
            continue
        mlist = re.match(r"\s*-\s+(.*)", line)
        if mlist and cur_key is not None:
            data.setdefault(cur_key, [])
            if isinstance(data[cur_key], list):
                data[cur_key].append(strip_quotes(mlist.group(1)))
            continue
        mkv = re.match(r"\s*([A-Za-z_]\w*)\s*:\s*(.*)", line)
        if mkv:
            key, val = mkv.group(1), mkv.group(2).strip()
            cur_key = key
            if val == "":
                data[key] = []  # дальше может быть блочный список
            elif val.startswith("[") and val.endswith("]"):
                inner = val[1:-1]
                data[key] = [strip_quotes(x) for x in inner.split(",") if x.strip()]
            else:
                data[key] = strip_quotes(val)
    return data


def collect_cascade(f):
    """Для контент-файла собрать теги (верхняя папка -> нижняя, с дедупом,
    сохраняя порядок) и тип (ближайшая папка побеждает)."""
    tags, seen, typ = [], set(), "книга"
    chain = [INBOX]
    cur = INBOX
    for part in f.parent.relative_to(INBOX).parts:
        cur = cur / part
        chain.append(cur)
    for d in chain:
        km = d / "_kindle.md"
        if not km.is_file():
            continue
        data = parse_kindle_md(km)
        for t in data.get("add_authors") or []:
            if t and t not in seen:
                seen.add(t)
                tags.append(t)
        if data.get("type"):
            typ = data["type"]
    return tags, typ


def orig_author(f):
    out = run([EBOOK_META, str(f)]).stdout
    for line in out.splitlines():
        m = re.match(r"\s*Author\(s\)\s*:\s*(.*)", line)
        if m:
            a = re.sub(r"\s*\[.*\]$", "", m.group(1).strip())
            return "" if a in ("", "Unknown") else a
    return ""


def build_authors(f, tags, typ):
    tags_str = " & ".join(tags)
    if typ == "документ":
        return tags_str
    parts = [p for p in (orig_author(f), tags_str) if p]
    return " & ".join(parts)


def clean_stem(f):
    name = f.name
    for ext in sorted(EBOOK_EXTS | {".pdf"}, key=len, reverse=True):
        if name.lower().endswith(ext):
            name = name[: -len(ext)]
    return name


def list_content():
    return sorted(p for p in INBOX.rglob("*")
                  if p.is_file() and p.name not in SKIP_NAMES)


def convert_one(f):
    """Конвертировать один файл -> staging. Возвращает (ok, сообщение).
    Без печати — для безопасного параллельного запуска."""
    tags, typ = collect_cascade(f)
    stem = clean_stem(f)
    ext = f.suffix.lower()

    if ext == ".pdf":
        prefix = ("[" + "_".join(tags) + "] ") if tags else ""
        dst = STAGING / (prefix + stem + ".pdf")
        shutil.copyfile(f, dst)
        return True, f"PDF как есть -> {dst.name}"

    authors = build_authors(f, tags, typ)
    out = STAGING / f"{stem}.{RICH}"
    r = run([EBOOK_CONVERT, str(f), str(out),
             "--output-profile", PROFILE, "--authors", authors])
    if r.returncode == 0 and out.exists():
        return True, f"{out.name}  [{authors}]"

    if out.exists():
        out.unlink()
    out = STAGING / f"{stem}.mobi"
    r2 = run([EBOOK_CONVERT, str(f), str(out), "--output-profile", PROFILE,
              "--authors", authors, "--mobi-file-type", "old"])
    if r2.returncode == 0 and out.exists():
        return True, f"{out.name} (MOBI6 фолбэк)  [{authors}]"
    last = (r.stderr or r.stdout).strip().splitlines()
    return False, f"ОШИБКА KFX и MOBI: {last[-1] if last else '?'}"


def kindle_connected():
    r = run([MTP_CLI, "--batch"], input="ls /\n")
    return "documents" in r.stdout


def cmd_convert(flt="", jobs=None):
    STAGING.mkdir(exist_ok=True)
    STATE.mkdir(exist_ok=True)
    jobs = jobs or int(os.environ.get("KINDLE_JOBS", "4"))
    files = [f for f in list_content() if not flt or flt in str(f.relative_to(INBOX))]
    if not files:
        print("Нет файлов по фильтру.")
        return
    print(f"Конвертирую {len(files)} файл(ов), параллельно: {jobs}")
    total, done, ok = len(files), 0, 0
    with ThreadPoolExecutor(max_workers=jobs) as ex:
        futs = {ex.submit(convert_one, f): f for f in files}
        for fut in as_completed(futs):
            name = futs[fut].name
            try:
                good, msg = fut.result()
            except Exception as e:
                good, msg = False, f"исключение: {e}"
            done += 1
            ok += 1 if good else 0
            print(f"  [{done}/{total}] {'✓' if good else '✗'} {name}: {msg}", flush=True)
    print(f"Готово: {ok}/{total} сконвертировано.")


def cmd_push():
    files = sorted(p for p in STAGING.iterdir()
                   if p.is_file() and p.name != ".gitkeep")
    if not files:
        print("staging пуст — сначала: kindle convert")
        return
    if not kindle_connected():
        print("Kindle не найден. Воткни кабель и закрой GUI OpenMTP.")
        sys.exit(1)
    batch = "".join(f'put "{f}" "{KINDLE_DOCS}"\n' for f in files)
    r = run([MTP_CLI, "--batch"], input=batch)
    print(r.stdout.strip().splitlines()[-1] if r.stdout.strip() else "")
    with (STATE / "uploaded.list").open("a", encoding="utf-8") as fh:
        for f in files:
            fh.write(f.name + "\n")
    print(f"Залито: {len(files)} файл(ов) в {KINDLE_DOCS}")


def cmd_status():
    inbox_n = len(list_content())
    staged = len([p for p in STAGING.iterdir() if p.name != ".gitkeep"]) if STAGING.exists() else 0
    hist = STATE / "uploaded.list"
    uploaded = len(set(hist.read_text(encoding="utf-8").split())) if hist.exists() else 0
    print(f"inbox:   {inbox_n} файл(ов)")
    print(f"staging: {staged} готово к заливке")
    print(f"залито (история): {uploaded}")
    print(f"Kindle: {'подключён' if kindle_connected() else 'не подключён'}")


def main():
    args = sys.argv[1:]
    jobs = None
    if "--jobs" in args:
        i = args.index("--jobs")
        jobs = int(args[i + 1])
        del args[i:i + 2]
    cmd = args[0] if args else ""
    if cmd == "convert":
        cmd_convert(args[1] if len(args) > 1 else "", jobs)
    elif cmd == "push":
        cmd_push()
    elif cmd == "status":
        cmd_status()
    elif cmd == "sync":
        cmd_convert("", jobs)
        cmd_push()
    else:
        print("usage: kindle {convert [подстрока] [--jobs N]|push|status|sync}")
        sys.exit(1)


if __name__ == "__main__":
    main()
